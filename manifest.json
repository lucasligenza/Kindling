{
  "manifest_version": 3,
  "name": "Kindling",
  "version": "1.0.0",
  "description": "Transform any article into an authentic Kindle e-ink reading experience",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Toggle Kindle Reader"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/readability.js",
        "content/reader.js",
        "content/settings.js",
        "content/progress.js",
        "content/highlights.js",
        "content/main.js"
      ],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
